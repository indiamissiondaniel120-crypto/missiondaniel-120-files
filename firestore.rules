
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isAdmin() {
      // Note: In this prototype, admins are mocked via hardcoded credentials.
      // This helper is kept for future expansion when admin UIDs are stored.
      return request.auth != null;
    }

    function isMentor() {
      return request.auth != null;
    }

    function isStudent() {
      return request.auth != null;
    }

    // --- CORE COLLECTIONS ---
    match /students/{studentId} {
      allow read, write: if true;
      match /activity/{activityId} {
        allow read, write: if true;
      }
    }
    
    match /mentors/{mentorId} {
      allow read, write: if true;
      match /activity/{activityId} {
        allow read, create, update: if true;
      }
    }

    match /courses/{courseId} {
      allow read, write: if true;
    }

    match /subjects/{subjectId} {
      allow read, write: if true;
    }

    match /materials/{materialId} {
      allow read, write: if true;
    }

    // --- PUBLIC DOUBT POOL ---
    match /publicDoubts/{doubtId} {
      allow read, list: if request.auth != null;

      allow create: if request.auth != null;

      allow update: if request.auth != null;
            
      allow delete: if request.auth != null;
    }

    // --- PRIVATE DOUBT CLEARANCE ---
    // Security Note: Since logical IDs differ from Auth UIDs in this prototype,
    // we allow authenticated access. Application logic handles filtering by student/mentor ID.
    match /privateDoubts/{doubtId} {
      allow read, list: if request.auth != null;
      
      allow create: if request.auth != null;
      
      allow update: if request.auth != null;
        
      allow delete: if request.auth != null;
    }
    
    match /admins/{adminId} {
      allow read: if true;
    }
  }
}
