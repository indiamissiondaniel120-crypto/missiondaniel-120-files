rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isMentor() {
      return isAuth() && exists(/databases/$(database)/documents/mentors/$(request.auth.uid));
    }

    function isStudent() {
      return isAuth() && exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    // --- CORE COLLECTIONS ---
    match /students/{studentId} {
      allow read, write: if true;
      match /activity/{activityId} {
        allow read, write: if true;
      }
    }
    
    match /mentors/{mentorId} {
      allow read, write: if true;
      match /activity/{activityId} {
        allow read, create, update: if true;
      }
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /materials/{materialId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // --- PRIVATE CHATS ---
    // Simplified to allow all authenticated users (Anonymous or otherwise) 
    // to read/write chat messages for the MVP.
    match /chats/{chatId} {
      allow read, write: if isAuth();

      match /messages/{messageId} {
        allow read, write: if isAuth();
      }
    }

    // --- PUBLIC DOUBT POOL ---
    match /publicDoubts/{doubtId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // --- ADMINS ---
    match /admins/{adminId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}