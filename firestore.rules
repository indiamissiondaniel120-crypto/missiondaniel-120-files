rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isMentor() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/mentors/$(request.auth.uid));
    }

    function isStudent() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    // --- CORE COLLECTIONS ---
    match /students/{studentId} {
      allow read, write: if true;
      match /activity/{activityId} {
        allow read, write: if true;
      }
    }
    
    match /mentors/{mentorId} {
      allow read, write: if true;
      match /activity/{activityId} {
        allow read, create, update: if true;
      }
    }

    match /courses/{courseId} {
      allow read, write: if true;
    }

    match /subjects/{subjectId} {
      allow read, write: if true;
    }

    match /materials/{materialId} {
      allow read, write: if true;
    }

    // --- PRIVATE CHATS (Student <=> Assigned Mentor) ---
    match /chats/{chatId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, list: if isAdmin() || isMentor() || isStudent();
        allow create, write: if request.auth != null;
      }
    }

    // --- PUBLIC DOUBT POOL (Public Student => All Mentors) ---
    match /publicDoubts/{doubtId} {
      allow read, list: if isAdmin() || isMentor() || (isStudent() && resource.data.studentId == request.auth.uid);

      allow create: if isAdmin() 
        || (isStudent() && request.resource.data.studentId == request.auth.uid && request.resource.data.status == 'open');

      allow update: if isAdmin()
        || (isMentor() 
            && resource.data.status == 'open' 
            && request.resource.data.status == 'answered');
            
      allow delete: if isAdmin();
    }
  }
}