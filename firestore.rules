
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isMentor() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/mentors/$(request.auth.uid));
    }

    function isStudent() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    // --- CORE COLLECTIONS ---
    match /students/{studentId} {
      allow read, write: if true;
      match /activity/{activityId} {
        allow read, write: if true;
      }
    }
    
    match /mentors/{mentorId} {
      allow read, write: if true;
      match /activity/{activityId} {
        allow read, create, update: if true;
      }
    }

    match /courses/{courseId} {
      allow read, write: if true;
    }

    match /subjects/{subjectId} {
      allow read, write: if true;
    }

    match /materials/{materialId} {
      allow read, write: if true;
    }

    // --- PUBLIC DOUBT POOL ---
    match /publicDoubts/{doubtId} {
      allow read, list: if isAdmin() || isMentor() || (isStudent() && resource.data.studentId == request.auth.uid);

      allow create: if isAdmin() 
        || (isStudent() && request.resource.data.studentId == request.auth.uid && request.resource.data.status == 'open');

      allow update: if isAdmin()
        || (isMentor() 
            && resource.data.status == 'open' 
            && request.resource.data.status == 'answered');
            
      allow delete: if isAdmin();
    }

    // --- PRIVATE DOUBT CLEARANCE ---
    match /privateDoubts/{doubtId} {
      allow read, list: if isAdmin() 
        || (isStudent() && resource.data.studentId == request.auth.uid)
        || (isMentor() && resource.data.mentorId == request.auth.uid);
      
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      
      allow update: if isAdmin()
        || (isMentor() && resource.data.mentorId == request.auth.uid)
        || (isStudent() && resource.data.studentId == request.auth.uid);
        
      allow delete: if isAdmin()
        || (isStudent() && resource.data.studentId == request.auth.uid);
    }
  }
}
