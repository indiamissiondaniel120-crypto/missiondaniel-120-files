
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow full access for development as the app uses local IDs for auth mapping
    match /students/{studentId} {
      allow read, write: if true;
      
      match /activity/{activityId} {
        allow read, write: if true;
      }
    }
    
    match /mentors/{mentorId} {
      allow read, write: if true;
    }

    match /chats/{chatId}/messages/{messageId} {
      // Allow read/write for participants and global read for admins
      allow read: if true; // simplified for dev, in prod check chatId contains user.id
      allow write: if true;
    }
  }
}
