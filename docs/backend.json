{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student registered in the DANIEL 120 platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "password": { "type": "string" },
        "name": { "type": "string" },
        "class": { "type": "string" },
        "mentorId": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "public_student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PublicDoubt": {
      "title": "PublicDoubt",
      "description": "A doubt asked by a public student in the Students Corner.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "className": { "type": "string" },
        "question": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "assigned", "answered"] },
        "mentorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrative user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      }
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session document.",
      "type": "object",
      "properties": {
        "assignedMentorId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": { "$ref": "#/backend/entities/Student" },
      "description": "Registered students."
    },
    "/publicDoubts/{doubtId}": {
      "schema": { "$ref": "#/backend/entities/PublicDoubt" },
      "description": "Doubts from the public Students Corner."
    },
    "/admins/{adminId}": {
      "schema": { "$ref": "#/backend/entities/Admin" },
      "description": "Administrative user records for security rules."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/backend/entities/Chat" },
      "description": "Private chat metadata."
    }
  }
}