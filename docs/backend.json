
{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student registered in the DANIEL 120 platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "password": { "type": "string" },
        "name": { "type": "string" },
        "class": { "type": "string" },
        "mentorId": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "public_student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PublicDoubt": {
      "title": "PublicDoubt",
      "description": "A doubt asked by a public student in the Students Corner.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "className": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "answered"] },
        "mentorId": { "type": "string" },
        "mentorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "openedAt": { "type": "string", "format": "date-time" },
        "answeredAt": { "type": "string", "format": "date-time" }
      }
    },
    "PrivateDoubt": {
      "title": "PrivateDoubt",
      "description": "A private doubt between a registered student and their assigned mentor.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "mentorId": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "answered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "openedAt": { "type": "string", "format": "date-time" },
        "answeredAt": { "type": "string", "format": "date-time" }
      }
    },
    "LiveSession": {
      "title": "LiveSession",
      "description": "An active live video class session.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "mentorId": { "type": "string" },
        "mentorName": { "type": "string" },
        "roomName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrative user record.",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": { "$ref": "#/backend/entities/Student" },
      "description": "Registered students."
    },
    "/publicDoubts/{doubtId}": {
      "schema": { "$ref": "#/backend/entities/PublicDoubt" },
      "description": "Doubts from the public Students Corner."
    },
    "/privateDoubts/{doubtId}": {
      "schema": { "$ref": "#/backend/entities/PrivateDoubt" },
      "description": "Private doubts between assigned students and mentors."
    },
    "/liveSessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/LiveSession" },
      "description": "Active live video classes."
    },
    "/admins/{adminId}": {
      "schema": { "$ref": "#/backend/entities/Admin" },
      "description": "Administrative user records for security rules."
    }
  }
}
