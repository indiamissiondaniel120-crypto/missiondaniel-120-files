
{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student registered in the DANIEL 120 platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The login ID for the student." },
        "password": { "type": "string", "description": "The login password for the student." },
        "name": { "type": "string", "description": "Full name of the student." },
        "schoolName": { "type": "string", "description": "Name of the school the student attends." },
        "location": { "type": "string", "description": "Geographical location of the student/school." },
        "class": { "type": "string", "description": "The academic stream or class (e.g., Class 10, NEET)." },
        "mentorId": { "type": "string", "description": "The ID of the assigned mentor." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of registration." }
      },
      "required": ["id", "password", "name", "class"]
    },
    "Mentor": {
      "title": "Mentor",
      "description": "A mentor who guides students.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Login ID for the mentor." },
        "password": { "type": "string", "description": "Login password for the mentor." },
        "name": { "type": "string", "description": "Full name of the mentor." },
        "expertise": { "type": "string", "description": "Subject or area of expertise." },
        "phone": { "type": "string", "description": "Contact number." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "password", "name"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Log of student activities (logins, material access).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["login", "logout", "pdf_view", "video_view", "inactivity_logout"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "duration": { "type": "number", "description": "Duration in seconds for views." },
        "metadata": { "type": "object", "description": "Additional info like title of material." }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat room.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean", "description": "Whether the message has been read by the recipient." }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of registered students."
    },
    "/mentors/{mentorId}": {
      "schema": "Mentor",
      "description": "Collection of registered mentors."
    },
    "/students/{studentId}/activity/{activityId}": {
      "schema": "ActivityLog",
      "description": "Real-time activity logs for a student."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages in a specific mentor-student chat room."
    }
  }
}
