
{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student registered in the DANIEL 120 platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "password": { "type": "string" },
        "name": { "type": "string" },
        "class": { "type": "string" },
        "mentorId": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "public_student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PublicDoubt": {
      "title": "PublicDoubt",
      "description": "A doubt asked by a public student in the Students Corner.",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "className": { "type": "string" },
        "question": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "assigned", "resolved"] },
        "mentorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Registered students."
    },
    "/publicDoubts/{doubtId}": {
      "schema": "PublicDoubt",
      "description": "Doubts from the public Students Corner."
    }
  }
}
